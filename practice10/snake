import pygame
import random
import time

# Инициализация
pygame.init()

# Настройки экрана
WIDTH = 800
HEIGHT = 600
CELL_SIZE = 20
screen = pygame.display.set_mode((WIDTH, HEIGHT))
pygame.display.set_caption("Pink Snake Sky Game")

# --- ТВОЯ ЦВЕТОВАЯ ПАЛИТРА ---
SKY_BLUE = (135, 206, 235)  # Небесно-голубой фон
PINK     = (255, 105, 180)  # Розовая змейка
RED      = (255, 0, 0)      # Красная еда
WHITE    = (255, 255, 255)  # Текст
BLACK    = (0, 0, 0)

# Шрифты
font_style = pygame.font.SysFont("Verdana", 25)
score_font = pygame.font.SysFont("Verdana", 35)

def show_info(score, level):
    """Отображение счета и уровня в углу экрана"""
    value = score_font.render(f"Score: {score}  Level: {level}", True, WHITE)
    screen.blit(value, [10, 10])

class Snake:
    def __init__(self):
        self.length = 1
        self.positions = [(WIDTH // 2, HEIGHT // 2)]
        self.direction = random.choice([(0, -1), (0, 1), (-1, 0), (1, 0)])
        self.score = 0
        self.level = 1
        self.speed = 10

    def get_head_position(self):
        return self.positions[0]

    def update(self):
        cur = self.get_head_position()
        x, y = self.direction
        new = (cur[0] + (x * CELL_SIZE), cur[1] + (y * CELL_SIZE))

        # 1. ПРОВЕРКА СТОЛКНОВЕНИЯ СО СТЕНАМИ
        if new[0] < 0 or new[0] >= WIDTH or new[1] < 0 or new[1] >= HEIGHT:
            return False

        # 2. ПРОВЕРКА СТОЛКНОВЕНИЯ С САМИМ СОБОЙ
        if len(self.positions) > 2 and new in self.positions[2:]:
            return False
        
        self.positions.insert(0, new)
        if len(self.positions) > self.length:
            self.positions.pop()
        return True

    def draw(self, surface):
        for p in self.positions:
            pygame.draw.rect(surface, PINK, (p[0], p[1], CELL_SIZE, CELL_SIZE))

class Food:
    def __init__(self, snake_positions):
        self.position = (0, 0)
        self.randomize_position(snake_positions)

    def randomize_position(self, snake_positions):
        """Генерация еды так, чтобы она не попала на змейку"""
        while True:
            self.position = (random.randint(0, (WIDTH - CELL_SIZE) // CELL_SIZE) * CELL_SIZE,
                             random.randint(0, (HEIGHT - CELL_SIZE) // CELL_SIZE) * CELL_SIZE)
            if self.position not in snake_positions:
                break

    def draw(self, surface):
        pygame.draw.rect(surface, RED, (self.position[0], self.position[1], CELL_SIZE, CELL_SIZE))

def main():
    snake = Snake()
    food = Food(snake.positions)
    clock = pygame.time.Clock()
    
    running = True
    while running:
        screen.fill(SKY_BLUE) # Установка фона

        for event in pygame.event.get():
            if event.type == pygame.QUIT:
                running = False
            elif event.type == pygame.KEYDOWN:
                if event.key == pygame.K_UP and snake.direction != (0, 1):
                    snake.direction = (0, -1)
                elif event.key == pygame.K_DOWN and snake.direction != (0, -1):
                    snake.direction = (0, 1)
                elif event.key == pygame.K_LEFT and snake.direction != (1, 0):
                    snake.direction = (-1, 0)
                elif event.key == pygame.K_RIGHT and snake.direction != (-1, 0):
                    snake.direction = (1, 0)

        # Движение змейки и проверка на Game Over
        if not snake.update():
            screen.fill(RED)
            msg = font_style.render("GAME OVER!Press Q-Quit or C-Play Again", True, WHITE)
            screen.blit(msg, [WIDTH / 6, HEIGHT / 3])
            pygame.display.update()
            
            # Ожидание выбора после проигрыша
            waiting = True
            while waiting:
                for event in pygame.event.get():
                    if event.type == pygame.KEYDOWN:
                        if event.key == pygame.K_q:
                            running = False
                            waiting = False
                        if event.key == pygame.K_c:
                            main() # Рестарт
            break

        # ПРОВЕРКА: СЪЕЛА ЛИ ЗМЕЙКА ЕДУ
        if snake.get_head_position() == food.position:
            snake.length += 1
            snake.score += 1
            food.randomize_position(snake.positions)
            
            # ЛОГИКА УРОВНЕЙ: каждые 3 съеденные еды - новый уровень
            if snake.score % 3 == 0:
                snake.level += 1
                snake.speed += 3 # УВЕЛИЧЕНИЕ СКОРОСТИ

        # Отрисовка
        snake.draw(screen)
        food.draw(screen)
        show_info(snake.score, snake.level)

        pygame.display.update()
        clock.tick(snake.speed)

    pygame.quit()

if __name__ == "__main__":
    main()